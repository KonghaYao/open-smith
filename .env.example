# ============================================
# Open Smith Environment Configuration
# ============================================

# Required: Master key for admin operations
MASTER_KEY=your-secret-master-key-change-this

# Optional: PostgreSQL/TimescaleDB connection string
# Comment out to use SQLite (default for development)
TRACE_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/open_smith

# Optional: Port for the server (default: 7765)
PORT=7765

# Optional: Node environment
NODE_ENV=production
