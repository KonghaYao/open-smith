# Open Smith 环境变量配置示例
# 复制此文件为 .env 并根据实际情况修改

# ========================================
# 必需的环境变量
# ========================================

# 管理员密钥 - 用于系统管理接口认证
# 警告: 请使用强随机字符串，不要泄露
MASTER_KEY=your-secure-master-key-here

# ========================================
# 数据库配置
# ========================================

# TimescaleDB/PostgreSQL 连接字符串
# 格式: postgresql://user:password@host:port/database
TRACE_DATABASE_URL=postgresql://open_smith:open_smith_password@localhost:5432/open_smith

# ========================================
# 可选的环境变量
# ========================================

# 自定义查询超时时间 (毫秒)
# ANALYTICS_QUERY_TIMEOUT=30000

# 自定义查询最大返回行数
# ANALYTICS_MAX_ROWS=10000

# ========================================
# OpenAI 配置 (用于 LLM 调用功能)
# ========================================

# OpenAI API 密钥 (可选, 如果使用 LLM 功能则必须配置)
# OPENAI_API_KEY=sk-your-openai-api-key-here

# OpenAI API 基础 URL (可选, 默认为 https://api.openai.com/v1)
# OPENAI_API_BASE=https://api.openai.com/v1

# ========================================
# 其他配置
# ========================================

# 附件存储路径 (默认为 ./attachments)
# ATTACHMENTS_DIR=./attachments

# 日志级别 (可选: debug, info, warn, error)
# LOG_LEVEL=info
